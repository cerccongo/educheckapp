{
  "name": "educheck-api",
  "version": "2.0.0",
  "description": "EduCheck school-monitoring REST API with role-based auth",
  "main": "server.js",
  "scripts": {
    "start":      "node server.js",
    "dev":        "nodemon server.js",
    "db:init":    "psql $DATABASE_URL -f db/schema.sql",
    "db:migrate": "psql $DATABASE_URL -f db/migrate_auth.sql"
  },
  "dependencies": {
    "bcryptjs":     "^2.4.3",
    "cors":         "^2.8.5",
    "dotenv":       "^16.4.5",
    "express":      "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg":           "^8.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": { "node": ">=18" }
}
